{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "OpenOCD_flash_win",
      "type": "process",
      "command": "Flash\\OpenOCD_flash.bat",
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "JLink_flash_win",
      "type": "process",
      "command": "Flash\\JLink_flash.bat",
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "OpenOCD_flash_linux",
      "type": "process",
      "command": "Flash/OpenOCD_flash.sh",
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "JLink_flash_linux",
      "type": "process",
      "command": "Flash/JLink_flash.sh",
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "Configure",
      "type": "shell",
      "command": "cmake",
      "args": [
        "-B",
        "build"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "problemMatcher": [],
      "detail": "CMake 配置"
    },
    {
      "label": "Build",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "build"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [],
      "detail": "CMake 生成"
    },
    {
      "label": "Clean_Rebuild",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "build",
        "--clean-first"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "problemMatcher": [],
      "detail": "CMake 清理重新生成"
    },
    {
      "label": "Clean",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "build",
        "--target",
        "clean"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "problemMatcher": [],
      "detail": "CMake 清理"
    },
  ]
}